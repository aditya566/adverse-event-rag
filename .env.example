# ═══════════════════════════════════════════════════════
# Adverse Event RAG — Environment Configuration
# Stack: Anthropic Claude | ChromaDB local | MedWatch 3500A
# ═══════════════════════════════════════════════════════

# Anthropic Claude (REQUIRED)
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-sonnet-4-20250514

# Embeddings - default is fully local, no API key needed
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
# EMBEDDING_MODEL=text-embedding-3-small   # OpenAI alternative
# OPENAI_API_KEY=sk-your-key-here

# ChromaDB - persists locally
CHROMA_PERSIST_DIR=./knowledge_base/vector_store/chroma_db

# CRM intake - advocates drop .txt or .csv exports here
CHART_NOTES_INTAKE_DIR=./data/crm_intake
CHART_NOTES_PROCESSED_DIR=./data/crm_processed

# Pharma PDFs - admin uses admin_upload.py to add docs
PHARMA_DOCS_DIR=./sample_data/pharma_docs

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Classifier thresholds
RETRIEVER_TOP_K=5
CONFIDENCE_THRESHOLD_AUTO=0.90       # above: standard review queue
CONFIDENCE_THRESHOLD_ESCALATE=0.60   # below: escalate to senior

# HIPAA - always true in production
ENABLE_PII_REDACTION=true

# Reports
REPORT_OUTPUT_DIR=./reports/output

# Daily batch scheduler
BATCH_SUBMISSION_TIME=17:00
BATCH_TIMEZONE=America/New_York

# Audit logs - 7 year retention per 21 CFR Part 314
LOG_LEVEL=INFO
AUDIT_LOG_RETENTION_DAYS=2555

# Company info (printed on MedWatch 3500A)
COMPANY_NAME=Acme Health Insurance
COMPANY_ADDRESS=123 Main St, City, ST 00000
COMPANY_PHONE=800-555-0100
